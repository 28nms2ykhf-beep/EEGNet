        # ... 前面的加载和维度处理代码保持不变 ...

        # 处理增强或默认裁剪
        if aug_params is None:
            # 原始样本：中心裁剪1536
            T = eeg.shape[-1]
            target_len = 1536
            if T >= target_len:
                start = (T - target_len) // 2
                eeg = eeg[:, :, start:start + target_len]
            else:
                # 长度不足则右侧补零
                pad = target_len - T
                eeg = F.pad(eeg, (0, pad))
        else:
            aug_type = aug_params['type']
            if aug_type == 'noise':
                eeg = add_gaussian_noise(eeg, aug_params['std'])
                # 噪声后仍需要统一裁剪（如果原始长度不是1536）
                T = eeg.shape[-1]
                if T != 1536:
                    # 中心裁剪或填充
                    if T > 1536:
                        start = (T - 1536) // 2
                        eeg = eeg[:, :, start:start+1536]
                    else:
                        pad = 1536 - T
                        eeg = F.pad(eeg, (0, pad))
            elif aug_type == 'scale':
                eeg = random_scale(eeg, aug_params['scale_range'])
                # 同样确保长度
                T = eeg.shape[-1]
                if T != 1536:
                    if T > 1536:
                        start = (T - 1536) // 2
                        eeg = eeg[:, :, start:start+1536]
                    else:
                        pad = 1536 - T
                        eeg = F.pad(eeg, (0, pad))
            elif aug_type == 'crop':
                start = aug_params['start']
                T = eeg.shape[-1]
                target_len = 1536
                # 如果起始点+1536超出范围，则调整起始点
                if start + target_len > T:
                    start = max(0, T - target_len)
                eeg = eeg[:, :, start:start + target_len]
                # 如果长度不足（理论上不会，但保险）
                if eeg.shape[-1] != target_len:
                    pad = target_len - eeg.shape[-1]
                    eeg = F.pad(eeg, (0, pad))
            # 可选的 channel 增强（如果有）
            elif aug_type == 'channel':
                eeg = channel_dropout(eeg, aug_params['drop_prob'])
                # 长度统一
                T = eeg.shape[-1]
                if T != 1536:
                    if T > 1536:
                        start = (T - 1536) // 2
                        eeg = eeg[:, :, start:start+1536]
                    else:
                        pad = 1536 - T
                        eeg = F.pad(eeg, (0, pad))

        # 最终确保形状为 (1, 18, 1536)（可加断言）
        assert eeg.shape == (1, 18, 1536), f"Shape mismatch: {eeg.shape}"
        return eeg, label, patient, session
